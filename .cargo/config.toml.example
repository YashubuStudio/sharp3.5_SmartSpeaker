[env]
# CUDA architecture settings for whisper-rs GPU acceleration
# Copy this file to .cargo/config.toml and set the appropriate value for your GPU:
#
# Common architectures:
#   GTX 10xx (Pascal):      "60;61"
#   RTX 20xx (Turing):      "75"
#   RTX 30xx (Ampere):      "86"
#   RTX 40xx (Ada):         "89"
#   RTX 50xx (Blackwell):   "120"
#
# Multiple architectures (for broader compatibility):
#   CMAKE_CUDA_ARCHITECTURES = "60;70;75;80;86;89"

CMAKE_CUDA_ARCHITECTURES = "120"
CUDAARCHS = "120"

# Allow unsupported Visual Studio version (e.g., VS 2025)
CUDAFLAGS = "-allow-unsupported-compiler"
CMAKE_CUDA_FLAGS = "-allow-unsupported-compiler"
NVCC_APPEND_FLAGS = "-allow-unsupported-compiler"
